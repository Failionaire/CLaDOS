{
  "name": "clados",
  "version": "1.0.0",
  "description": "Claude Logic and Development Operating System — multi-agent software development pipeline",
  "bin": {
    "clados": "bin/clados.js"
  },
  "main": "dist/orchestrator/cli.js",
  "files": [
    "bin/",
    "dist/",
    "agents/",
    "agent-registry.json",
    "ui/dist/"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "build:ui": "cd ui && npm install && npm run build",
    "build:all": "npm run build && npm run build:ui",
    "prepare": "npm run build:all",
    "dev:orchestrator": "tsc --watch --project tsconfig.json",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.36.0",
    "express": "^4.18.2",
    "ws": "^8.16.0",
    "write-file-atomic": "^5.0.1",
    "open": "^10.1.0",
    "uuid": "^9.0.0",
    "js-yaml": "^4.1.0",
    "typescript": "^5.9.3",
    "tree-sitter": "^0.21.0",
    "tree-sitter-typescript": "^0.21.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/ws": "^8.5.10",
    "@types/node": "^20.11.0",
    "@types/uuid": "^9.0.7",
    "@types/js-yaml": "^4.0.9",
    "@types/write-file-atomic": "^4.0.3"
  }
}
